{
  "name": "itgo-marketplace",
  "version": "1.0.0",
  "description": "ITGO - Marketplace TI OnDemand de Latinoamérica",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
